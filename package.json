{
  "name": "trackflow",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "pnpm --filter @trackflow/shared-types build && pnpm --filter @trackflow/backend start:dev",
    "dev:dashboard": "pnpm --filter @trackflow/dashboard dev",
    "dev:mobile": "pnpm --filter @trackflow/mobile start",
    "build:all": "pnpm -r build",
    "build:dashboard": "pnpm --filter @trackflow/dashboard build",
    "db:migrate": "pnpm --filter @trackflow/backend migration:run",
    "db:seed": "pnpm --filter @trackflow/backend seed:run",
    "infra:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d postgres redis emqx",
    "infra:down": "docker compose -f infrastructure/docker/docker-compose.yml down",
    "infra:logs": "docker compose -f infrastructure/docker/docker-compose.yml logs -f",
    "docker:up": "docker compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infrastructure/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "@types/passport-jwt": "^4.0.1",
    "typescript": "^5.3.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild"
    ]
  }
}
